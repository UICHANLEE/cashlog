## 프론트 (Vite) — 브라우저에 변수만 올림
#
# 사진 분석: mock (파일명 휴리스틱) | remote (/api/analyze 등)
VITE_PHOTO_ANALYSIS_MODE=mock
#
# remote일 때 호출 주소 (비두면 브라우저 origin 기준 `/api/analyze`)
# 로컬: `npm run dev` + `vercel dev` 함께 쓸 때 vite proxy가 `/api` → localhost:3000
# VITE_ANALYZE_API_URL=http://127.0.0.1:3000/api/analyze
#
## Vercel / 서버 (Git에 넣지 말 것) — 코드에 직접 넣으면 브라우저에 노출됨
# OPENAI_API_KEY=
# 선택: 모델 (기본 gpt-4o-mini)
# OPENAI_VISION_MODEL=gpt-4o-mini
